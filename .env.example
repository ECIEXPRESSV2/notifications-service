# --- Base de datos (PostgreSQL en NeonDB) ---
DATABASE_URL=                        # NeonDB, con sslmode=require

# --- Bus de eventos (RabbitMQ en CloudAMQP) ---
RABBITMQ_URL=                        # CloudAMQP, formato amqps://user:pass@host/vhost

# --- Canal Email (Resend) ---
RESEND_API_KEY=                      # re_... ; si se deja vacío, el email se loguea en consola (sandbox)
MAIL_FROM=ECIExpress <no-reply@eciexpress.edu.co>

# --- Canal WhatsApp ---
# Proveedor: 'cloud' (Meta WhatsApp Cloud API, oficial) u 'openwa' (servidor gratis
# @open-wa/wa-automate sobre WhatsApp Web). Si faltan las credenciales del proveedor
# elegido, el mensaje se loguea en consola (sandbox).
WHATSAPP_PROVIDER=cloud

# Opción A) cloud — Meta WhatsApp Cloud API
WHATSAPP_API_URL=https://graph.facebook.com/v21.0
WHATSAPP_PHONE_NUMBER_ID=            # id del número emisor en Meta Cloud API
WHATSAPP_TOKEN=                      # token permanente de la app de WhatsApp

# Opción B) openwa — servidor propio: npx @open-wa/wa-automate --api -p 8002 [--api-key KEY]
# Poner WHATSAPP_PROVIDER=openwa y apuntar WHATSAPP_API_URL al servidor (no a Meta).
# WHATSAPP_API_URL=http://localhost:8002
WHATSAPP_OPENWA_API_KEY=             # solo si levantaste el servidor con --api-key

# --- Canal SMS (Twilio) ---
# Si se dejan vacíos, el SMS se loguea en consola (sandbox).
TWILIO_ACCOUNT_SID=                  # AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                         # número emisor verificado (+57...)

# --- Canal Push (Firebase Cloud Messaging) ---
# Si se deja vacío, el push se loguea en consola (sandbox).
FCM_SERVER_KEY=                      # server key del proyecto Firebase

# --- General ---
NODE_ENV=development
PORT=3006
TZ=America/Bogota

# URL base del front (la usan las plantillas de correo para enlaces, ej. "Ver mi billetera").
# En desarrollo apunta al Vite local; al desplegar cambiar por la URL pública del front.
FRONTEND_URL=http://localhost:5173
